{
  "name": "PSP1",
  "version": "1.0.0",
  "description": "Advanced layer management plugin for Adobe Photoshop 2025 with one-tap operations, bulk styling, and intelligent automation",
  "main": "index.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.{js,ts} --fix",
    "format": "prettier --write src/**/*.{js,ts,html,css}",
    "type-check": "tsc --noEmit",
    "package": "uxp package",
    "install-plugin": "uxp plugin install"
  },
  "keywords": [
    "photoshop",
    "uxp",
    "plugin",
    "layer-management",
    "automation",
    "design-tools"
  ],
  "author": "Layer Manager Pro Team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "fast-check": "^3.15.1",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iceyxsm/PSP1.git"
  },
  "bugs": {
    "url": "https://github.com/iceyxsm/PSP1/issues"
  },
  "homepage": "https://github.com/iceyxsm/PSP1#readme"
}