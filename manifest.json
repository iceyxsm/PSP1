{
  "manifestVersion": 5,
  "id": "com.psp1.photoshop",
  "name": "PSP1 - Layer Manager Pro",
  "version": "1.0.3",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "25.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "layerManagerPanel",
      "label": {
        "default": "PSP1 - Layer Manager Pro"
      },
      "minimumSize": {"width": 280, "height": 400},
      "maximumSize": {"width": 800, "height": 1200},
      "preferredDockedSize": {"width": 320, "height": 600},
      "preferredFloatingSize": {"width": 350, "height": 650},
      "icons": [
        {"width": 23, "height": 23, "path": "icons/dark.png", "scale": [1, 2], "theme": ["darkest", "dark", "medium"]},
        {"width": 23, "height": 23, "path": "icons/light.png", "scale": [1, 2], "theme": ["lightest", "light"]}
      ]
    },
    {
      "type": "command",
      "id": "oneClickGroup",
      "label": {
        "default": "One-Click Group"
      }
    },
    {
      "type": "command", 
      "id": "bulkColorText",
      "label": {
        "default": "Bulk Color Text"
      }
    },
    {
      "type": "command",
      "id": "bulkColorShapes", 
      "label": {
        "default": "Bulk Color Shapes"
      }
    },
    {
      "type": "command",
      "id": "imageReplace",
      "label": {
        "default": "Replace Image"
      }
    }
  ],
  "icons": [
    { "width": 23, "height": 23, "path": "icons/icon_dark.png", "scale": [1, 2], "theme": ["dark", "darkest"], "species": ["generic"] },
    { "width": 23, "height": 23, "path": "icons/icon_light.png", "scale": [1, 2], "theme": ["lightest", "light"], "species": ["generic"] }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "clipboard": "readAndWrite",
    "network": {
      "domains": [
        "https://github.com"
      ]
    },
    "launchProcess": {
      "schemes": ["https"],
      "extensions": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".tiff", ".webp", ".svg"]
    }
  },
  "uiEntry": {
    "type": "panel",
    "id": "layerManagerPanel"
  }
}